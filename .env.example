# Copy to .env and fill in locally. Never commit .env or real keys.
# See docs/project_spec.md §6 for authoritative behavior.

# Required when using the TMDB provider (TV/film metadata).
TERMRENAMER_TMDB_API_KEY=

# TheTVDB v4 — set when selecting TheTVDB as the TV provider.
TERMRENAMER_TVDB_API_KEY=
# Optional; required for some subscriber accounts.
# TERMRENAMER_TVDB_SUBSCRIBER_PIN=

# OMDb — optional film metadata fallback (P2-01).
# TERMRENAMER_OMDB_API_KEY=

# HTTP request timeout in seconds (default applied in code if unset).
TERMRENAMER_HTTP_TIMEOUT_SECONDS=30

# Retry / backoff (defaults in code if unset).
TERMRENAMER_HTTP_MAX_ATTEMPTS=4
TERMRENAMER_HTTP_BACKOFF_BASE_SECONDS=0.5
TERMRENAMER_HTTP_JITTER=true

# Optional: separate output roots (scan still uses the working directory in the TUI).
# Film and TV are independent. Ignored when folder rename is disabled (filename-only renames).
# TERMRENAMER_FILM_DEST_FOLDER=/Volumes/media/films_output    # macOS/Linux example; Windows: K:\films_output
# TERMRENAMER_TV_DEST_FOLDER=/Volumes/media/tv_output          # macOS/Linux example; Windows: K:\tv_output

# Rename layout (defaults false): enable canonical show/film folder moves; second applies to TV when first is on.
# TERMRENAMER_ENABLE_FOLDER_RENAME=true
# TERMRENAMER_ENABLE_SEASON_FOLDERS=true

# Optional: SQLite metadata cache (performance only; safe to delete).
# TERMRENAMER_CACHE_DB_PATH=/path/to/termrenamer-cache.db

# Reserved for future file logging (path read in settings; bootstrap uses stderr first).
# While the TUI is running, stdlib logging is routed to the Logs tab (RichLog), not raw stderr.
# For capture outside the TUI or early bootstrap errors, see docs/runbook.md. Never commit secrets.
# TERMRENAMER_LOG_FILE=termrenamer.log
